<Window x:Class="Urbano_WPF.Views.Login.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Urbano_WPF.Views.Login"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:vm="clr-namespace:Urbano_WPF.ViewModels.Login"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        Title="Đăng nhập" 
        Height="200" 
        Width="350">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="1"
            Margin="20 0">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBox
                Grid.Row="0"
                Height="35"
                Style="{StaticResource TextBoxExtend}"
                hc:InfoElement.TitleWidth="90"
                hc:InfoElement.TitlePlacement="Left"
                hc:InfoElement.Title="Tên đăng nhập:"
                Text="{Binding Username, Mode=TwoWay}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding LoginCommand}"/>
                </TextBox.InputBindings>
            </TextBox>

            <hc:PasswordBox
                Grid.Row="1"
                Height="35"
                Style="{StaticResource PasswordBoxPlusBaseStyle}"
                UnsafePassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                hc:InfoElement.TitleWidth="90"
                hc:InfoElement.TitlePlacement="Left"
                hc:InfoElement.Title="Mật khẩu:"
                IsSafeEnabled="False">
                <hc:PasswordBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding LoginCommand}"/>
                </hc:PasswordBox.InputBindings>
            </hc:PasswordBox>
        </Grid>

        <hc:UniformSpacingPanel
            Spacing="15"
            Grid.Row="2"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0">

            <Button
                Content="Hủy"
                Width="100"
                Height="30"
                Command="{Binding CancelCommand}"/>

            <Button
                Content="Đăng nhập"
                Width="100"
                Height="30"
                Background="{StaticResource PrimaryActionBrush}"
                BorderBrush="{StaticResource PrimaryActionBrush}"
                Foreground="White"
                hc:BorderElement.CornerRadius="5"
                Command="{Binding LoginCommand}"/>

        </hc:UniformSpacingPanel>

    </Grid>
</Window>
