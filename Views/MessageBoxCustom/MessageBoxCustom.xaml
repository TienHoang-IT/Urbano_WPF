<Window x:Class="Urbano_WPF.Views.MessageBoxCustom.MessageBoxCustom"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Urbano_WPF.Views.MessageBoxCustom"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        ResizeMode="NoResize"
        Topmost="True"
        KeyDown="Window_KeyDown"
        Title="MessageBoxCustom"
        Background="Transparent"
        AllowsTransparency="True"
        Height="200" 
        Width="450">
    <Border
        CornerRadius="8"
        Background="White">
        <Grid
            Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border
                Background="Transparent"
                Height="45"
                MouseDown="Border_MouseDown">
                <TextBlock Name="txtTitle"
                       Text="Title"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="20"/>
            </Border>

            <Separator Grid.Row="1"/>

            <TextBlock
            x:Name="txtMessage"
            Grid.Row="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="18"
            Text="Message"/>

            <Grid
            Grid.Row="3"
            Height="45">

                <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Orientation="Horizontal">
                    <Button
                    x:Name="btnYes"
                    Grid.Column="0"
                    Width="100"
                    HorizontalAlignment="Right"
                    Margin="30 0"
                    Content="Yes"
                    Click="btnYes_Click"
                    Style="{StaticResource ButtonPrimary}"/>

                    <Button
                    x:Name="btnNo"
                    Grid.Column="1"
                    Width="100"
                    HorizontalAlignment="Left"
                    Margin="30 0"
                    Content="No"
                    Click="btnNo_Click"/>
                </StackPanel>

                <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Orientation="Horizontal">

                    <Button
                    x:Name="btnOk"
                    Grid.Column="0"
                    Width="100"
                    HorizontalAlignment="Right"
                    Margin="30 0"
                    Content="Ok"
                    Click="btnOk_Click"
                    Style="{StaticResource ButtonPrimary}"/>

                    <Button
                    x:Name="btnCancel"
                    Grid.Column="1"
                    Width="100"
                    HorizontalAlignment="Left"
                    Margin="30 0"
                    Content="Cancel"
                    Click="btnCancel_Click"/>

                </StackPanel>

                <!--<Button
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Width="120"
                HorizontalAlignment="Center"
                Content="Ok"/>-->

            </Grid>

        </Grid>
    </Border>
</Window>
