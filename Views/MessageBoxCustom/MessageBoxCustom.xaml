<Window x:Class="Urbano_WPF.Views.MessageBoxCustom.MessageBoxCustom"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Urbano_WPF.Views.MessageBoxCustom"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        ResizeMode="NoResize"
        Topmost="True"
        Title="MessageBoxCustom" 
        Height="250" 
        Width="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border
            Height="45">
            <TextBlock Name="txtTitle"
                       Text="Title"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="20"/>
        </Border>

        <Separator Grid.Row="1"/>

        <Grid
            Grid.Row="3"
            Height="45">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Width="120"
                HorizontalAlignment="Right"
                Margin="30 0"
                Content="Yes"/>

            <Button
                Grid.Column="1"
                Width="120"
                HorizontalAlignment="Left"
                Margin="30 0"
                Content="No"/>
            
            <Button
                Grid.Column="0"
                Width="120"
                HorizontalAlignment="Right"
                Margin="30 0"
                Content="Ok"/>

            <Button
                Grid.Column="1"
                Width="120"
                HorizontalAlignment="Left"
                Margin="30 0"
                Content="Cancel"/>

            <Button
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Width="120"
                HorizontalAlignment="Center"/>

        </Grid>

    </Grid>
</Window>
