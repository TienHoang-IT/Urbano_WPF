<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="ColorOffWhite">#EAE7DC</Color>
    <Color x:Key="ColorBeige">#D8C3A5</Color>
    <Color x:Key="ColorStone">#8E8D8A</Color>
    <Color x:Key="ColorSalmon">#E98074</Color>
    <Color x:Key="ColorBrickRed">#E85A4F</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource ColorOffWhite}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorBeige}"/>
    <SolidColorBrush x:Key="SubtleTextBrush" Color="{StaticResource ColorStone}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource ColorSalmon}"/>
    <SolidColorBrush x:Key="PrimaryActionBrush" Color="{StaticResource ColorBrickRed}"/>

</ResourceDictionary>